# ─────────────────────────────────────────────
#  1031 Exchange Forum Monitor — Environment
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Reddit API ────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
# Type: script
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=1031ExchangeMonitor/1.0 by u/your_reddit_username

# Subreddits to monitor (comma-separated, no spaces)
SUBREDDITS=realestateinvesting,RealEstate,tax,personalfinance

# ── Anthropic / Claude API ────────────────────
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Email (Gmail) ─────────────────────────────
# Use an App Password, NOT your real Gmail password.
# Enable 2FA then generate at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_APPROVER=approver@example.com

# ── Approval Server ───────────────────────────
APPROVAL_HOST=localhost
APPROVAL_PORT=5055

# ── General ───────────────────────────────────
DB_PATH=monitor.db
POLL_INTERVAL=300
